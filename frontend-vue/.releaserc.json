{
  "branches": [
    "main",
    {
      "name": "dev-python",
      "prerelease": "beta"
    }
  ],
  "tagFormat": "frontend-v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "scope": [
            "frontend",
            "frontend-*",
            "ui",
            "web"
          ],
          "scopeOnly": true
        },
        "releaseRules": [
          {
            "type": "feat",
            "scope": "frontend*",
            "release": "minor"
          },
          {
            "type": "feat",
            "scope": "ui",
            "release": "minor"
          },
          {
            "type": "feat",
            "scope": "web",
            "release": "minor"
          },
          {
            "type": "fix",
            "scope": "frontend*",
            "release": "patch"
          },
          {
            "type": "fix",
            "scope": "ui",
            "release": "patch"
          },
          {
            "type": "fix",
            "scope": "web",
            "release": "patch"
          },
          {
            "scope": "backend*",
            "release": false
          }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "scope": [
            "frontend",
            "frontend-*",
            "ui",
            "web"
          ],
          "scopeOnly": true
        },
        "writerOpts": {
          "commitsSort": [
            "scope",
            "subject"
          ]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "package.json",
          "CHANGELOG.md"
        ],
        "message": "chore(release): frontend-v${nextRelease.version} [skip ci]"
      }
    ],
    "@semantic-release/github"
  ]
}
